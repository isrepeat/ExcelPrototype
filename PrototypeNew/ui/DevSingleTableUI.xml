<?xml version="1.0" encoding="UTF-8"?>
<page xmlns="urn:excelprototype:profiles" version="1">
  <grid anchorCell="A1">
      <stackPanel at="r2c2" orientation="vertical">
        <control
          type="Button"
          name="BackToDev"
          caption="Back To Dev UI"
          style="actionWarning"
          onClick="{Binding Module=ex_Test;Method=fn_TEST_RenderDevUI}"
          spanColls="4"
          spanRows="2"/>

        <control
          type="TableList"
          name="TablesListFast"
          itemsSource="{PageRuntimeSource='RuntimeItems.Test.Tables'}"
          spanColls="12"
          spanRows="220"/>
      </stackPanel>
    </grid>

<styles>
    <controlStyle
      name="actionWarning"
      backColor="#ED7D31"
      textColor="#0A0A0A"
      borderColor="#A84912"
      borderWeight="1.25"
      fontName="Calibri"
      fontSize="11"
      fontBold="true"/>

    <controlStyle
      name="tableSection"
      backColor="#173A5E"
      textColor="#EAF6FF"
      borderColor="#0E2239"
      borderWeight="1.25"
      fontName="Calibri"
      fontSize="11"
      fontBold="true"/>

    <controlStyle
      name="tableHeader"
      backColor="#2B4A6B"
      textColor="#DDEEFF"
      borderColor="#1F3650"
      borderWeight="1"
      fontName="Calibri"
      fontSize="10"
      fontBold="true"/>

    <controlStyle
      name="tableCell"
      backColor="#3A3A3A"
      textColor="#F0F0F0"
      borderColor="#2A2A2A"
      borderWeight="1"
      fontName="Calibri"
      fontSize="10"
      fontBold="false"/>

    <controlStyle
      name="tableSpacer"
      backColor="#1F1F1F"
      textColor="#1F1F1F"
      borderColor="#1F1F1F"
      borderWeight="hairline"
      fontName="Calibri"
      fontSize="8"
      fontBold="false"/>

    <stylePipelineStage name="default">
      <layer name="sheet-base">
        <rule target="sheet"
              styles="{
                backColor:#1F1F1F;
                fontColor:#EAEAEA;
                borderColor:#000000;
                borderWeight:thin;
              }"/>
      </layer>
    </stylePipelineStage>
  </styles>
</page>
