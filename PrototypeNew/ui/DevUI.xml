<?xml version="1.0" encoding="UTF-8"?>
<page xmlns="urn:excelprototype:profiles" version="1">
  <grid anchorCell="A1">
      <stackPanel at="r2c2" orientation="horizontal">
          <stackPanel orientation="vertical">
              <control
                type="Button"
                name="Open Table Part Styles UI"
                caption="Open Table Part Styles Demo"
                style="actionWarning"
                onClick="{Binding Module=ex_Test;Method=m_TEST_RenderDevTablePartStylesUI}"
                spanColls="3"
                spanRows="2"
                />
              <control
                type="Button"
                name="Update UI"
                caption="Open Table List Demo"
                style="actionWarning"
                onClick="{Binding Module=ex_Test;Method=m_TEST_RenderDevTableListUI}"
                spanColls="3"
                spanRows="2"
                />
              <control
                type="Button"
                name="Update UI Single"
                caption="Open Single Table Demo"
                style="actionWarning"
                onClick="{Binding Module=ex_Test;Method=m_TEST_RenderDevSingleTableUI}"
                spanColls="3"
                spanRows="2"
                />
            </stackPanel>
      </stackPanel>

      <stackPanel at="r2c6" orientation="horizontal">
          <control
            type="Config"
            name="DevConfig"
            itemsSource="{PageRuntimeSource='RuntimeItems.PageMain.Config'}"
            tableName="cfgDevUi"
            spanColls="3"
            spanRows="50"
            />
          <stackPanel orientation="horizontal">
              <control
                type="Select"
                name="ConfigProfilePicker"
                itemsSource="{PageRuntimeSource='RuntimeItems.PageMain.ConfigProfiles'}"
                placeholder="Choose profile"
                style="configSelectHeader"
                panelStyle="configSelectPanel"
                itemStyle="configSelectItem"
                itemHeight="18"
                itemMargin="2"
                spanColls="2"
                spanRows="2"
                />

              <stackPanel spanColls="1" spanRows="1"/>
              
              <control
                type="Select"
                name="ConfigModePicker"
                itemsSource="{PageRuntimeSource='RuntimeItems.PageMain.ConfigModes'}"
                placeholder="Choose mode"
                style="configSelectHeader"
                panelStyle="configSelectPanel"
                itemStyle="configSelectItem"
                itemHeight="18"
                itemMargin="2"
                spanColls="2"
                spanRows="2"
                />

              <stackPanel spanColls="1" spanRows="1"/>

              <control
                type="Button"
                name="SaveConfigProfile"
                caption="Save Config Profile"
                style="actionWarning"
                onClick="{Binding Module=ex_PageMainActions;Method=m_SaveCurrentConfigProfile}"
                spanColls="2"
                spanRows="2"
                />
          </stackPanel>
      </stackPanel>

      <stackPanel at="r2c17" orientation="vertical">
        <control
          type="Button"
          name="UpdateSheet"
          caption="Update Sheet"
          style="actionWarning"
          onClick="{Binding Module=ex_Test;Method=m_TEST_UpdateCurrentPage}"
          spanColls="3"
          spanRows="2"
          />
        <control
          type="Button"
          name="ToggleLogging"
          dataContext="{GlobalRuntimeSource='Settings'}"
          caption="{Binding Path=IsLoggingEnabled;TrueAs=Logging [[[ok]]On[[/ok]]];FalseAs=Logging [[[color=#FF0000]]Off[[/color]]]}"
          style="actionWarning"
          onClick="{Binding Module=ex_Core;Method=m_Dev_ToggleLogging}"
          spanColls="3"
          spanRows="2"
          />
        <control
          type="Button"
          name="UpdateCodeSize"
          caption="Update Code Size"
          style="actionWarning"
          onClick="{Binding Module=ex_Core;Method=m_Dev_UpdateCodeBySize}"
          spanColls="3"
          spanRows="2"
          />
        <control
          type="Button"
          name="UpdateCodeDate"
          caption="Update Code Date"
          style="actionWarning"
          onClick="{Binding Module=ex_Core;Method=m_Dev_UpdateCodeByDate}"
          spanColls="3"
          spanRows="2"
          />
        <control
          type="Button"
          name="UpdateCodeFull"
          caption="Update Code Full"
          style="actionWarning"
          onClick="{Binding Module=ex_Core;Method=m_Dev_UpdateAllModules}"
          spanColls="3"
          spanRows="2"
          />
        <control
          type="Button"
          name="OpenCoreModule"
          caption="Open ex_Core"
          style="actionWarning"
          onClick="{Binding Module=ex_Core;Method=m_Dev_OpenCoreModule}"
          spanColls="3"
          spanRows="2"
          />
      </stackPanel>
  </grid>

  <styles>
    <controlStyle
      name="actionWarning"
      backColor="#ED7D31"
      textColor="#0A0A0A"
      borderColor="#A84912"
      borderWeight="1.25"
      fontName="Calibri"
      fontSize="11"
      fontBold="false"/>

    <controlStyle
      name="configSelectHeader"
      backColor="#438E20"
      textColor="#0A0A0A"
      borderColor="#285D14"
      borderWeight="1"
      fontName="Calibri"
      fontSize="11"
      fontBold="false"/>

    <controlStyle
      name="configSelectPanel"
      backColor="#2B3138"
      textColor="#F1F5F9"
      borderColor="#1C2024"
      borderWeight="0.75"
      fontName="Calibri"
      fontSize="10"
      fontBold="false"/>

    <controlStyle
      name="configSelectItem"
      backColor="#3B424A"
      textColor="#F8FAFC"
      borderColor="#282D32"
      borderWeight="0.75"
      fontName="Calibri"
      fontSize="10"
      fontBold="false"/>

    <stylePipelineStage name="default">
      <layer name="dark-base">
        <rule target="sheet"
              styles="{ 
                backColor:#262626;
                fontColor:#EBEBEB;
                borderColor:#000000;
                borderWeight:thin;
                width:8.625;
                rowHeight:15.95;
              }"/>
      </layer>

      <layer name="dark-primary-action">
        <rule target="range"
              selector="address=B2:D3"
              styles="{ 
                backColor:#0F766E;
                fontColor:#E6FFFA;
                borderColor:#134E4A;
                fontBold:true;
              }"/>
      </layer>

      <layer name="config-parts">
        <rule target="controlPart"
              selector="type=config;part=attr"
              styles="{
                width:5;
              }"/>

        <rule target="controlPart"
              selector="type=config;part=key"
              styles="{
                width:30;
              }"/>

        <rule target="controlPart"
              selector="type=config;part=value"
              styles="{
                width:40;
              }"/>

        <rule target="controlPart"
              selector="type=config;part=attrhash"
              styles="{
                backColor:#3A3422;
                fontColor:#FDE68A;
                borderColor:#594F2D;
                borderWeight:thin;
                fontBold:true;
              }"/>

        <rule target="controlPart"
              selector="type=config;part=attrrx"
              styles="{
                backColor:#1D3342;
                fontColor:#BAE6FD;
                borderColor:#2A4A5F;
                borderWeight:thin;
                fontBold:false;
                fontItalic:true;
              }"/>
      </layer>
    </stylePipelineStage>
  </styles>
</page>
