<?xml version="1.0" encoding="UTF-8"?>
<page xmlns="urn:excelprototype:profiles" version="1">
  <grid anchorCell="A1">
      <stackPanel at="r2c2" orientation="horizontal">
          <control
            type="Config"
            name="DevConfig"
            itemsSource="{PageRuntimeSource='RuntimeItems.PageMain.Config'}"
            tableName="cfgDevUi"
            spanColls="3"
            spanRows="50"
            />
          <stackPanel orientation="horizontal">
              <control
                type="Select"
                name="ConfigProfilePicker"
                dataContext="{PageRuntimeSource='RuntimeObjects.PageMain.Controller'}"
                itemsSource="{PageRuntimeSource='RuntimeItems.PageMain.ConfigProfiles'}"
                dropDownOpened="{Binding Method=OnConfigProfileDropDownOpened}"
                placeholder="Choose profile"
                style="configSelectHeader"
                panelStyle="configSelectPanel"
                itemStyle="configSelectItem"
                itemHeight="18"
                itemMargin="2"
                spanColls="4"
                spanRows="2"
                />

              <stackPanel spanColls="1" spanRows="1"/>

              <control
                type="Select"
                name="ConfigModePicker"
                dataContext="{PageRuntimeSource='RuntimeObjects.PageMain.Controller'}"
                itemsSource="{PageRuntimeSource='RuntimeItems.PageMain.ConfigModes'}"
                dropDownOpened="{Binding Method=OnConfigModeDropDownOpened}"
                placeholder="Choose mode"
                style="configSelectHeader"
                panelStyle="configSelectPanel"
                itemStyle="configSelectItem"
                itemHeight="18"
                itemMargin="2"
                spanColls="4"
                spanRows="2"
                />

              <stackPanel spanColls="1" spanRows="1"/>

              <control
                type="Button"
                name="SaveConfigProfile"
                caption="Save Config Profile"
                style="actionWarning"
                dataContext="{PageRuntimeSource='RuntimeObjects.PageMain.Controller'}"
                onClick="{Binding Method=SaveCurrentConfigProfile}"
                spanColls="4"
                spanRows="2"
                />
          </stackPanel>
      </stackPanel>

      <stackPanel at="r2c24" orientation="vertical">
        <control
          type="Button"
          name="OpenPersonalCard"
          caption="Open PersonalCard"
          style="actionWarning"
          dataContext="{PageRuntimeSource='RuntimeObjects.PageMain.Controller'}"
          onClick="{Binding Method=OpenPersonalCardPage}"
          spanColls="5"
          spanRows="2"
          />
        <control
          type="Button"
          name="UpdateSheet"
          caption="Update Sheet"
          style="actionWarning"
          onClick="{Binding Module=rt_PageManager;Method=fn_RenderActivePage}"
          spanColls="5"
          spanRows="2"
          />
        <control
          type="Button"
          name="ClearPagesExceptMain"
          caption="Clear Pages (except Main)"
          style="actionWarning"
          dataContext="{PageRuntimeSource='RuntimeObjects.PageMain.Controller'}"
          onClick="{Binding Method=ClearWorkbookPagesExceptMain}"
          spanColls="5"
          spanRows="2"
          />
        <control
          type="Button"
          name="ToggleLogging"
          dataContext="{GlobalRuntimeSource='Settings'}"
          caption="{Binding Path=IsLoggingEnabled;TrueAs=Logging [[[ok]]On[[/ok]]];FalseAs=Logging [[[color=#FF0000]]Off[[/color]]]}"
          style="actionWarning"
          onClick="{Binding Module=ex_Core;Method=fn_Dev_ToggleLogging}"
          spanColls="5"
          spanRows="2"
          />
        <control
          type="Button"
          name="UpdateCodeSize"
          caption="Update Code Size"
          style="actionWarning"
          onClick="{Binding Module=ex_Core;Method=fn_Dev_UpdateCodeBySize}"
          spanColls="5"
          spanRows="2"
          />
        <control
          type="Button"
          name="UpdateCodeDate"
          caption="Update Code Date"
          style="actionWarning"
          onClick="{Binding Module=ex_Core;Method=fn_Dev_UpdateCodeByDate}"
          spanColls="5"
          spanRows="2"
          />
        <control
          type="Button"
          name="UpdateCodeFull"
          caption="Update Code Full"
          style="actionWarning"
          onClick="{Binding Module=ex_Core;Method=fn_Dev_UpdateAllModules}"
          spanColls="5"
          spanRows="2"
          />
        <control
          type="Button"
          name="OpenCoreModule"
          caption="Open ex_Core"
          style="actionWarning"
          onClick="{Binding Module=ex_Core;Method=fn_Dev_OpenCoreModule}"
          spanColls="5"
          spanRows="2"
          />
      </stackPanel>
  </grid>

  <styles>
    <controlStyle
      name="actionWarning"
      backColor="#ED7D31"
      textColor="#0A0A0A"
      borderColor="#A84912"
      borderWeight="1.25"
      fontName="Calibri"
      fontSize="11"
      fontBold="false"/>

    <controlStyle
      name="configSelectHeader"
      backColor="#438E20"
      textColor="#0A0A0A"
      borderColor="#285D14"
      borderWeight="1"
      fontName="Calibri"
      fontSize="11"
      fontBold="false"/>

    <controlStyle
      name="configSelectPanel"
      backColor="#2B3138"
      textColor="#F1F5F9"
      borderColor="#1C2024"
      borderWeight="0.75"
      fontName="Calibri"
      fontSize="10"
      fontBold="false"/>

    <controlStyle
      name="configSelectItem"
      backColor="#3B424A"
      textColor="#F8FAFC"
      borderColor="#282D32"
      borderWeight="0.75"
      fontName="Calibri"
      fontSize="10"
      fontBold="false"/>

    <stylePipelineStage name="default">
      <layer name="dark-base">
        <rule target="sheet"
              styles="{ 
                backColor:#262626;
                fontColor:#EBEBEB;
                borderColor:#000000;
                borderWeight:thin;
                width:4;
                rowHeight:16;
                cellType:text;
              }"/>
      </layer>

      <layer name="config-parts">
        <rule target="controlPart"
              selector="type=config;part=attr"
              styles="{
                width:4;
              }"/>

        <rule target="controlPart"
              selector="type=config;part=key"
              styles="{
                width:38;
              }"/>

        <rule target="controlPart"
              selector="type=config;part=value"
              styles="{
                width:70;
                overflow:wrap;
                rowHeight:auto;
              }"/>

        <rule target="controlPart"
              selector="type=config;part=attrhash"
              styles="{
                backColor:#3A3422;
                fontColor:#FDE68A;
                borderColor:#594F2D;
                borderWeight:thin;
                fontBold:true;
              }"/>

        <rule target="controlPart"
              selector="type=config;part=attrrx"
              styles="{
                backColor:#1D3342;
                fontColor:#BAE6FD;
                borderColor:#2A4A5F;
                borderWeight:thin;
                fontBold:false;
                fontItalic:true;
              }"/>
      </layer>

      <layer name="layout-debug-bounds">
        <rule target="layoutBound"
              selector="tag=grid"
              styles="{
                borderColor:#8B5CF6;
                borderWeight:medium;
                borderLineStyle:solid;
              }"/>

        <rule target="layoutBound"
              selector="tag=control"
              styles="{
                borderColor:#FF0000;
                borderWeight:thin;
                borderLineStyle:solid;
              }"/>

        <rule target="layoutBound"
              selector="tag=stackpanel;tagDepth=0"
              styles="{
                borderColor:#444444;
                borderWeight:medium;
                borderLineStyle:dash;
              }"/>

        <rule target="layoutBound"
              selector="tag=stackpanel;tagDepth=1"
              styles="{
                borderColor:#5E5E5E;
                borderWeight:medium;
                borderLineStyle:dash;
              }"/>

        <rule target="layoutBound"
              selector="tag=stackpanel;tagDepth=2"
              styles="{
                borderColor:#777777;
                borderWeight:medium;
                borderLineStyle:dash;
              }"/>

       <rule target="layoutBound"
              selector="tag=stackpanel;tagDepth=3:10"
              styles="{
                borderColor:#999999;
                borderWeight:medium;
                borderLineStyle:dash;
              }"/>
      </layer>
    </stylePipelineStage>
  </styles>
</page>
