<?xml version="1.0" encoding="UTF-8"?>
<page xmlns="urn:excelprototype:profiles" version="1">
  <templates>
    <template name="tableSingleItemTpl">
      <control
        type="TableSingle"
        name="TableItem"
        itemsSource="{Binding Path=.}"
        spanColls="12"
        spanRows="8"/>
    </template>
  </templates>
    <grid anchorCell="A1">
      <stackPanel at="r2c2" orientation="vertical">
        <control
          type="Button"
          name="BackToDev"
          caption="Back To Dev UI"
          style="actionWarning"
          onClick="{Binding Module=ex_Test;Method=fn_TEST_RenderDevUI}"
          spanColls="4"
          spanRows="2"/>

        <list
          itemsSource="{PageRuntimeSource='RuntimeItems.Test.Tables'}"
          itemsSourceTemplate="tableSingleItemTpl"
          orientation="vertical"
          spanColls="12"
          spanRows="220"/>
      </stackPanel>
    </grid>

<styles>
    <controlStyle
      name="actionWarning"
      backColor="#ED7D31"
      textColor="#0A0A0A"
      borderColor="#A84912"
      borderWeight="1.25"
      fontName="Calibri"
      fontSize="11"
      fontBold="true"/>

    <stylePipelineStage name="default">
      <layer name="sheet-base">
        <rule target="sheet"
              styles="{
                backColor:#1F1F1F;
                fontColor:#EAEAEA;
                borderColor:#000000;
                borderWeight:thin;
              }"/>
      </layer>
    </stylePipelineStage>
  </styles>
</page>
