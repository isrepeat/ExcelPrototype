<?xml version="1.0" standalone="yes"?>
<stylePipeline xmlns="urn:excelprototype:profiles" version="1">
  <sheetPipeline page="Dev">
    <stage name="default">
      <layer name="dev-base" priority="100" enabled="true">
        <rule target="range"
              selector="address=A:XFD"
              styles="{
                backColor:#262626;
                fontColor:#EBEBEB;
                borderColor:#000000;
                borderWeight:thin;
              }"/>
      </layer>

      <layer name="dev-config-table-base" priority="200" enabled="true">
        <rule target="row"
              selector="kind=configall;col=1:4"
              styles="{
                backColor:#1E1E1E;
                fontColor:#EBEBEB;
                fontBold:false;
              }"/>
      </layer>

      <layer name="dev-config-table-header" priority="210" enabled="true">
        <rule target="row"
              selector="kind=configheader;col=1:4"
              styles="{
                fontBold:true;
                horizontal:center;
                vertical:center;
              }"/>
      </layer>

      <layer name="dev-config-table-layout" priority="215" enabled="true">
        <rule target="column"
              selector="col=1"
              styles="{
                width:5;
              }"/>
        <rule target="column"
              selector="col=2"
              styles="{
                width:42;
              }"/>
        <rule target="column"
              selector="col=3"
              styles="{
                width:42;
              }"/>
        <rule target="column"
              selector="col=4"
              styles="{
                width:25;
              }"/>

        <rule target="row"
              selector="kind=configdata;col=1"
              styles="{
                horizontal:center;
                vertical:center;
                overflow:clip;
              }"/>
        <rule target="row"
              selector="kind=configmarker;col=1"
              styles="{
                horizontal:center;
                vertical:center;
                overflow:clip;
              }"/>

        <rule target="row"
              selector="kind=configdata;col=2"
              styles="{
                horizontal:left;
                vertical:center;
                overflow:clip;
              }"/>
        <rule target="row"
              selector="kind=configmarker;col=2"
              styles="{
                horizontal:left;
                vertical:center;
                overflow:clip;
              }"/>

        <rule target="row"
              selector="kind=configdata;col=3:4"
              styles="{
                horizontal:left;
                vertical:center;
                overflow:wrap;
              }"/>
        <rule target="row"
              selector="kind=configmarker;col=3:4"
              styles="{
                horizontal:left;
                vertical:center;
                overflow:wrap;
              }"/>
      </layer>

      <layer name="dev-config-table-note-column" priority="220" enabled="true">
        <rule target="row"
              selector="kind=configdata;col=4"
              styles="{
                fontColor:#A8A8A8;
              }"/>
      </layer>

      <layer name="dev-config-table-marker" priority="230" enabled="true">
        <rule target="row"
              selector="kind=configmarker;col=1:4"
              styles="{
                backColor:#2D2D2D;
                fontColor:#EBEBEB;
                fontBold:false;
              }"/>
        <rule target="row"
              selector="kind=configmarker;col=2"
              styles="{
                fontBold:true;
                fontColor:#F5F5F5;
              }"/>
      </layer>

      <layer name="dev-config-table-locked-placeholder" priority="235" enabled="true">
        <rule target="row"
              selector="kind=configlockedplaceholder;col=3"
              styles="{
                backColor:#3A3220;
                fontColor:#FFD27A;
                fontBold:true;
                horizontal:left;
              }"/>
      </layer>
    </stage>
  </sheetPipeline>
</stylePipeline>
