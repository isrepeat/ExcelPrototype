<?xml version="1.0" standalone="yes"?>
<stylePipeline xmlns="urn:excelprototype:profiles" version="1">
  <sheetPipeline page="g_PersonTimeline">
    <stage name="default">
      <layer name="pc-base" priority="100" enabled="true">
        <rule target="sheet"
              styles="{
                fontName:'Times New Roman';
                fontSize:12;
                backColor:#222222;
                fontColor:#EBEBEB;
                horizontal:center;
                vertical:center;
                rowHeight:20;
                borderColor:#000000;
                borderWeight:thin;
              }"/>
      </layer>

      <layer name="pc-output-pre-autofit" priority="200" enabled="true">
        <rule target="row"
              selector="kind=header"
              styles="{
                overflow:clip;
              }"/>
        <rule target="row"
              selector="kind=section"
              styles="{
                overflow:clip;
              }"/>
      </layer>

      <layer name="pc-output-autofit" priority="210" enabled="true">
        <rule target="sheet"
              styles="{
                autoFitColumns:true;
              }"/>
      </layer>

      <layer name="pc-output-clamp-columns" priority="220" enabled="true">
        <rule target="sheet"
              styles="{
                minWidth:5;
                maxWidth:15;
              }"/>
      </layer>

      <layer name="pc-output-section" priority="230" enabled="true">
        <rule target="row"
              selector="kind=section"
              styles="{
                backColor:#161616;
                fontColor:#D7A763;
                fontBold:true;
                horizontal:left;
                overflow:clip;
                rowHeight:20;
              }"/>
        <rule target="row"
              selector="kind=section;col=1:3"
              styles="{
                mergeColumns:3;
                horizontal:center;
                vertical:center;
              }"/>
      </layer>

      <layer name="pc-output-header" priority="240" enabled="true">
        <rule target="row"
              selector="kind=header"
              styles="{
                backColor:#222222;
                fontColor:#68D947;
                fontBold:true;
                overflow:wrap;
                autoHeight:true;
              }"/>
      </layer>

      <layer name="pc-output-content" priority="250" enabled="true">
        <rule target="row"
              selector="kind=content"
              styles="{
                backColor:#222222;
                fontColor:#EBEBEB;
                overflow:wrap;
                autoHeight:true;
              }"/>
      </layer>

      <layer name="pc-output-specificcolumns" priority="300" enabled="true">
        <rule target="column"
              selector="mapKey=Events.Sheet[EventsOut].Map[Note]"
              styles="{
                width:35;
                overflow:wrap;
              }"/>
        <rule target="column"
              selector="mapKey=Daily.Sheet[DailyEvents].Map[InNum]"
              styles="{
                width:9;
                overflow:wrap;
              }"/>
        <rule target="column"
              selector="mapKey=Daily.Sheet[DailyEvents].Map[InDate]"
              styles="{
                width:11;
                overflow:wrap;
              }"/>
        <rule target="column"
              selector="mapKey=Daily.Sheet[DailyEvents].Map[DocNote]"
              styles="{
                width:20;
                overflow:wrap;
              }"/>
        <rule target="column"
              selector="mapKey=Daily.Sheet[DailyEvents].Map[VlkNum]"
              styles="{
                width:15;
                overflow:wrap;
              }"/>
      </layer>

      <layer name="pc-virtual-added" priority="305" enabled="true">
          <rule target="columnkind"
            selector="kind=header|virtual"
              styles="{
                backColor:#3A2E1A;
                fontColor:#FFDFA8;
                fontBold:true;
              }"/>
          <rule target="columnkind"
            selector="kind=content|virtual"
              styles="{
                backColor:#2A2418;
                fontColor:#F5E6C5;
              }"/>
        <rule target="rowkind"
              selector="kind=virtual"
              styles="{
                backColor:#2A2418;
                fontColor:#F5E6C5;
              }"/>
      </layer>

      <layer name="pc-partialmatch-autoheight" priority="480" enabled="true">
        <rule target="row"
              selector="kind=partialmatch"
              styles="{
                autoHeight:true;
              }"/>
      </layer>

      <layer name="pc-postwarnings" priority="500" enabled="true"/>
    </stage>

    <stage name="postProcess">
      <layer name="pc-postprocess-header" priority="100" enabled="true">
        <rule target="row"
              selector="kind=postprocessheader;col=1:6"
              styles="{
                mergeColumns:6;
                horizontal:left;
                overflow:wrap;
                backColor:#161616;
                fontColor:#F5D08A;
                fontSize:12;
                minRowHeight:24;
                autoHeight:true;
                customAutoHeight-margin-top:5;
                customAutoHeight-margin-bottom:5;
              }"/>
      </layer>

      <layer name="pc-postprocess-footer" priority="110" enabled="true">
        <rule target="row"
              selector="kind=postprocessfooter;col=1:6"
              styles="{
                mergeColumns:6;
                horizontal:left;
                overflow:wrap;
                backColor:#161616;
                fontColor:#F5D08A;
                fontSize:12;
                minRowHeight:24;
                autoHeight:true;
                customAutoHeight-margin-top:5;
                customAutoHeight-margin-bottom:5;
              }"/>
      </layer>
    </stage>

    <stage name="banners">
      <layer name="pc-banner-base" priority="100" enabled="true">
        <rule target="rowkind"
              selector="kind=errorbanner|warningbanner|notebanner;col=1:8"
              styles="{
                mergeColumns:8;
                overflow:wrap;
                horizontal:left;
                vertical:center;
                minRowHeight:24;
                autoHeight:true;
                customAutoHeight-margin-top:10;
                customAutoHeight-margin-bottom:10;
                borderWeight:thin;
              }"/>
      </layer>

      <layer name="pc-banner-warning" priority="110" enabled="true">
        <rule target="rowkind"
              selector="kind=warningbanner;col=1:8"
              styles="{
                backColor:#4C3F10;
                fontColor:#FFE599;
                borderColor:#3B320D;
              }"/>
      </layer>

      <layer name="pc-banner-error" priority="120" enabled="true">
        <rule target="rowkind"
              selector="kind=errorbanner;col=1:8"
              styles="{
                backColor:#161616;
                fontColor:#FFFFFF;
                borderColor:#111111;
              }"/>
      </layer>

      <layer name="pc-banner-note" priority="125" enabled="true">
        <rule target="rowkind"
              selector="kind=notebanner;col=1:8"
              styles="{
                backColor:#2A2A2A;
                fontColor:#FFE599;
                borderColor:#575757;
              }"/>
      </layer>

      <layer name="pc-banner-title" priority="130" enabled="true">
        <rule target="rowkind"
              selector="kind=errorbannertitle|warningbannertitle|notebannertitle;col=1:8"
              styles="{
                fontBold:true;
              }"/>
      </layer>

      <layer name="pc-layout-banner-base" priority="140" enabled="true">
        <rule target="rowkind"
              selector="kind=errorbannerlayout|warningbannerlayout|notebannerlayout"
              styles="{
                mergeColumns:8;
                overflow:wrap;
                horizontal:left;
                vertical:center;
                minRowHeight:24;
                autoHeight:true;
                customAutoHeight-margin-top:10;
                customAutoHeight-margin-bottom:10;
                borderWeight:thin;
              }"/>
      </layer>

      <layer name="pc-layout-banner-warning" priority="150" enabled="true">
        <rule target="rowkind"
              selector="kind=warningbannerlayout"
              styles="{
                backColor:#4C3F10;
                fontColor:#FFE599;
                borderColor:#3B320D;
              }"/>
      </layer>

      <layer name="pc-layout-banner-error" priority="160" enabled="true">
        <rule target="rowkind"
              selector="kind=errorbannerlayout"
              styles="{
                backColor:#161616;
                fontColor:#FFFFFF;
                borderColor:#111111;
              }"/>
      </layer>

      <layer name="pc-layout-banner-note" priority="170" enabled="true">
        <rule target="rowkind"
              selector="kind=notebannerlayout"
              styles="{
                backColor:#2A2A2A;
                fontColor:#FFE599;
                borderColor:#575757;
              }"/>
      </layer>

      <layer name="pc-layout-banner-title" priority="180" enabled="true">
        <rule target="rowkind"
              selector="kind=errorbannerlayouttitle|warningbannerlayouttitle|notebannerlayouttitle"
              styles="{
                fontBold:true;
              }"/>
      </layer>
    </stage>
  </sheetPipeline>
</stylePipeline>