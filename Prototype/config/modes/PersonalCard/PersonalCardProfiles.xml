		<fetchAdditionalData tableRef="Daily.Sheet[DailyEvents]">
			DEFINE $CurrentTable AS Src;

				/* Контекст, который движок заполняет в SEARCH_* блоках */
				DEFINE DATABASE Ctx {
					sectionData: [
						sectionType,
						sectionTitle
					],
					metaData: [
						metaVacation,
						metaRank,
						metaFio,
						metaPosition,
						metaRaportTVO,
						metaRaportFrom,
						metaInNum,
						metaInDate,
						metaDocNote,
						metaDocNum,
						metaDocDate
					]
				};

			FIND[Src.FIO == $Key] {
				// Ищем последний заголовок раздела выше owner-строки
				SEARCH_ABOVE
					@IF(NOT @IsEmpty(Src.Type))
					@PUSH(Ctx.sectionData) {
						.sectionType = Src.Type,
						.sectionTitle = Src.Hospital
					}
					@KEEP(LAST);

					// Собираем meta-строки ниже owner-строки.
					// Для сохранения contiguous-прохода считаем валидной и строку-маркер атрибута DocNum="!"
					// даже при пустом DocNote (она будет проигнорирована позже на этапе шаблонизации).
					SEARCH_BELOW
						@IF(Src.DocNote == "ТВО" OR Src.DocNum == "!" OR (Src.FIO == "" AND NOT @IsEmpty(Src.DocNote)))
						@PUSH(Ctx.metaData) {
							.metaVacation = Src.Vacation,
							.metaRank = Src.Rank,
							.metaFio = Src.FIO,
							.metaPosition = Src.Position,
							.metaRaportTVO = Src.RaportTVO,
							.metaRaportFrom = Src.RaportFrom,
							.metaInNum = Src.InNum,
							.metaInDate = Src.InDate,
							.metaDocNote = Src.DocNote,
							.metaDocNum = Src.DocNum,
							.metaDocDate = Src.DocDate
						}
						@KEEP(CONTIGUOUS);

				GENERATE {
					DEFINE COLUMNS [MetaType, OwnerFio, SectionType, SectionTitle];
					DEFINE ROW {
						MetaType = "owner",
						OwnerFio = $Key,
						SectionType = @LAST(Ctx.sectionData).sectionType,
						SectionTitle = @LAST(Ctx.sectionData).sectionTitle
					};

					@FOREACH(md : Ctx.metaData) {
						DEFINE ROW {
							Vacation = md.metaVacation,
							Rank = md.metaRank,
							FIO = md.metaFio,
							Position = md.metaPosition,
							RaportTVO = md.metaRaportTVO,
							RaportFrom = md.metaRaportFrom,
							InNum = md.metaInNum,
							InDate = md.metaInDate,
							DocNote = md.metaDocNote,
							DocNum = md.metaDocNum,
							DocDate = md.metaDocDate,
							MetaType = "meta",
							OwnerFio = $Key,
							SectionType = @LAST(Ctx.sectionData).sectionType,
							SectionTitle = @LAST(Ctx.sectionData).sectionTitle
						};
					};
				}
			}
		</fetchAdditionalData>
