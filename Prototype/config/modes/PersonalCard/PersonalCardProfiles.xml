<?xml version="1.0" standalone="yes"?>
<profiles version="1" xmlns="urn:excelprototype:profiles">
	<profile name="Default">
		<ui>
			<control name="ddProfile" visible="false"/>
			<control name="ddMode" visible="false"/>
			<control name="btnClear" visible="true"/>
			<control name="btnMode" visible="true"/>
			<control name="btnPersonalCard" visible="true"/>
			<control name="btnComparing" visible="false"/>
			<control name="btnUpdateCode" visible="true"/>
			<control name="btnCustomProfile" visible="true"/>
			<control name="btnCustomProfileOption_1" visible="false"/>
			<control name="btnCustomProfileOption_2" visible="false"/>
			<control name="btnCustomMode" visible="true"/>
			<control name="btnCustomModeOption_1" visible="false"/>
			<control name="btnCustomModeOption_2" visible="false"/>
		</ui>
		<v key="Source.Main.FilePath">..\TESTS\GetReferences\PeopleStateUA.xlsx</v>
		<v key="Source.Main.SheetAliases">StateMain</v>
		<v key="Source.Events.FilePath">..\TESTS\GetReferences\PeopleEventsUA.xlsx</v>
		<v key="Source.Events.SheetAliases">EventsMain</v>
		<v key="CommonKey">Іванов Іван Іванович</v>
		<v type="#" key="StateMain"/>
		<v key="Main.Sheet[StateMain].Type">State</v>
		<v key="Main.Sheet[StateMain].SheetName">StateSheet</v>
		<v key="Main.Sheet[StateMain].Key">FIO</v>
		<v key="Main.Sheet[StateMain].FieldsAliases">FIO; BirthDate; City; Phone</v>
		<v key="Main.Sheet[StateMain].Map[FIO]">ПІБ</v>
		<v key="Main.Sheet[StateMain].Map[BirthDate]">Дата народження</v>
		<v key="Main.Sheet[StateMain].Map[City]" styles="{width:20;overflow:shrink}">Місто</v>
		<v key="Main.Sheet[StateMain].Map[Phone]">Телефон</v>
		<v type="#" key="EventsMain"/>
		<v key="Events.Sheet[EventsMain].Type">Events</v>
		<v key="Events.Sheet[EventsMain].SheetName">EventsSheet</v>
		<v key="Events.Sheet[EventsMain].Key">FIO</v>
		<v key="Events.Sheet[EventsMain].FieldsAliases">RecordNo; EventDate; EventType; Department; Position; Salary</v>
		<v key="Events.Sheet[EventsMain].Sort">RecordNo</v>
		<v key="Events.Sheet[EventsMain].Map[FIO]">ПІБ</v>
		<v key="Events.Sheet[EventsMain].Map[RecordNo]">№</v>
		<v key="Events.Sheet[EventsMain].Map[EventDate]">Дата події</v>
		<v key="Events.Sheet[EventsMain].Map[EventType]">Тип події</v>
		<v key="Events.Sheet[EventsMain].Map[Department]">Відділ</v>
		<v key="Events.Sheet[EventsMain].Map[Position]">Посада</v>
		<v key="Events.Sheet[EventsMain].Map[Salary]">Оклад</v>
		<v key=""/>
		<v key="Output.Sheets">StateMain; EventsMain</v>
	</profile>
	<profile name="Test">
		<v key="Source.Main.FilePath">..\dsc_StateSrc.xlsx</v>
		<v key="Source.Main.SheetAliases">StateMain</v>
		<v key="Source.Events.FilePath">..\dsc_EventsSrc.xlsx</v>
		<v key="Source.Events.SheetAliases">EventsIn; EventsOut</v>
		<v key="CommonKey">ТКАЧЕНКО Сергій Олександрович</v>
		<v type="#" key="StateMain"/>
		<v key="Main.Sheet[StateMain].Type">State</v>
		<v key="Main.Sheet[StateMain].SheetName">ШПС</v>
		<v key="Main.Sheet[StateMain].Key">FIO</v>
		<v key="Main.Sheet[StateMain].FieldsAliases">FIO; IPN; ZV; Position</v>
		<v key="Main.Sheet[StateMain].Map[ZV]">Військове звання</v>
		<v key="Main.Sheet[StateMain].Map[FIO]">Прізвище, ім’я, по батькові|ПІБ</v>
		<v key="Main.Sheet[StateMain].Map[Position]">Повна назва посади</v>
		<v key="Main.Sheet[StateMain].Map[IPN]">ІПН</v>
		<v type="#" key="EventsIn"/>
		<v key="Events.Sheet[EventsIn].Type">Events</v>
		<v key="Events.Sheet[EventsIn].SheetName">4. Тимчасово прибулі</v>
		<v key="Events.Sheet[EventsIn].FieldsAliases">ZV; FIO; ComesFrom;</v>
		<v key="Events.Sheet[EventsIn].Key">FIO</v>
		<v key="Events.Sheet[EventsIn].Sort">FIO</v>
		<v key="Events.Sheet[EventsIn].Map[ZV]">55|Звання</v>
		<v key="Events.Sheet[EventsIn].Map[FIO]">56|ПІБ</v>
		<v key="Events.Sheet[EventsIn].Map[ComesFrom]">58|Звідки прибув</v>
		<v type="#" key="EventsOut"/>
		<v key="Events.Sheet[EventsOut].Type">Events</v>
		<v key="Events.Sheet[EventsOut].SheetName">5. Тимчасово відсутні</v>
		<v key="Events.Sheet[EventsOut].FieldsAliases">ZV; FIO; EventReason; City; Date; Note; Ticket</v>
		<v key="Events.Sheet[EventsOut].Key">FIO</v>
		<v key="Events.Sheet[EventsOut].Sort">Date</v>
		<v key="Events.Sheet[EventsOut].Map[ZV]">65|Звання</v>
		<v key="Events.Sheet[EventsOut].Map[FIO]">66|ПІБ</v>
		<v key="Events.Sheet[EventsOut].Map[EventReason]">68|Причинна вибуття</v>
		<v key="Events.Sheet[EventsOut].Map[City]">69|Місце вибуття</v>
		<v key="Events.Sheet[EventsOut].Map[Date]">71 (А)|Дата наказу</v>
		<v key="Events.Sheet[EventsOut].Map[Ticket]">Стовпець1|Номер квитка</v>
		<v key="Events.Sheet[EventsOut].Map[Note]" styles="{width: 40; autoHeight: true}">76|Замітки</v>
		<v key=""/>
		<v key="Output.Sheets">StateMain; EventsOut; EventsIn</v>
		<postProcessScript>
			for (row in Events.Sheet[EventsOut].rows) {
				if (row.column[Date] == "12.07.2025") {
					callMacro("ex_PostProcessActions.m_HighlightRow", row, "#FF0000");
					callMacro("ex_PostProcessActions.m_HighlightRowCell", row, "Ticket", "#00FF00");
				}
			}

			if (Events.Sheet[EventsOut].count != "0") {
				callMacro("ex_PostProcessActions.m_AppendPostProcessFooterText", "EventsOut rows: {Events.Sheet[EventsOut].count}. Last date: {Events.Sheet[EventsOut].lastRow.column[Date]}");
			}

			if (Events.Sheet[EventsOut].count != "0" and Events.Sheet[EventsOut].count != "1") {
				callMacro("ex_PostProcessActions.m_AppendPostProcessFooterText", "Prev date: {Events.Sheet[EventsOut].prevRow.column[Date]}");
			}

			let dateMapKey = callMacro("ex_ResultRuntimeAdapter.m_BuildMapKey", "Events", "EventsOut", "Date");
			callMacro("ex_PostProcessActions.m_AppendPostProcessFooterText", "DSL var test. dateMapKey={dateMapKey}");
			if (dateMapKey == "Events.Sheet[EventsOut].Map[Date]") {
				callMacro("ex_PostProcessActions.m_AppendPostProcessFooterText", dateMapKey);
			}
		</postProcessScript>
		<ui>
			<control name="ddProfile" visible="false"/>
			<control name="ddMode" visible="false"/>
			<control name="btnClear" visible="true"/>
			<control name="btnMode" visible="true"/>
			<control name="btnPersonalCard" visible="true"/>
			<control name="btnComparing" visible="false"/>
			<control name="btnUpdateCode" visible="true"/>
			<control name="btnCustomProfile" visible="true"/>
			<control name="btnCustomProfileOption_1" visible="false"/>
			<control name="btnCustomProfileOption_2" visible="false"/>
			<control name="btnCustomMode" visible="true"/>
			<control name="btnCustomModeOption_1" visible="false"/>
			<control name="btnCustomModeOption_2" visible="false"/>
		</ui>
	</profile>
</profiles>
