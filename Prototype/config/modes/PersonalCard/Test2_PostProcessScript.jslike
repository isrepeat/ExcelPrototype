				FIO:{row.column[FIO]};
				Position:{row.column[Position]};
				OutDate:{fullDateFrom};
				IsAssignToDuty:{isAssignToDuty};
				AssignToDutyRank:{assignToDutyRank};
				AssignToDutyFIO:{assignToDutyFIO};
				AssignToDutyPosition:{assignToDutyPosition};
				RaportFrom:{row.column[RaportFrom]};
				HasDuplicateRaport:{hasDuplicateRaport};
				DuplicateRaportFrom:{duplicateRaportFrom};
				DuplicateRaportTVO:{duplicateRaportTVO};
				DuplicateInNumFull:{duplicateInNumFull};
				DuplicateInDate:{duplicateInDate};
				InNumFull:{inNumFull};
				InDate:{fullInDate};
				DocNum:{row.column[DocNum]};
				DocDate:{fullDocDate};
				`,
				"#66CCFF"
			);
		}

		if (sectionType == "11") {
			txt = callMacro(
				"ex_ResultTemplatesParser.m_ReplaceMultiPlaceholders",
				txt,
				$`
				Rank:{row.column[Rank]};
				FIO:{row.column[FIO]};
				Position:{row.column[Position]};
				IsAssignToDuty:{isAssignToDuty};
				AssignToDutyRank:{assignToDutyRank};
				AssignToDutyFIO:{assignToDutyFIO};
				AssignToDutyPosition:{assignToDutyPosition};
				RaportFrom:{row.column[RaportFrom]};
				InNumFull:{inNumFull};
				InDate:{fullInDate};
				`,
				"#66CCFF"
			);
		}

		if (sectionType == "8" || sectionType == "9") {
			txt = callMacro(
				"ex_ResultTemplatesParser.m_ReplaceMultiPlaceholders",
				txt,
				$`
				Rank:{row.column[Rank]};
				FIO:{row.column[FIO]};
				Position:{row.column[Position]};
				City:{row.column[Vacation]};
				DaysCount:{normalizedDaysCount};
				AdditionalWayDays:{additionalWayDays};
				OutDate:{fullDateFrom};
				ReturnDate:{fullDateTo};
				IsAssignToDuty:{isAssignToDuty};
				AssignToDutyRank:{assignToDutyRank};
				AssignToDutyFIO:{assignToDutyFIO};
