<?xml version="1.0" standalone="yes"?>
<stylePipeline xmlns="urn:excelprototype:profiles" version="1">
  <sheetPipeline page="g_Result">
    <stage name="default">
      <layer name="tc-base" priority="100" enabled="true">
        <rule target="sheet"
              styles="{
                backColor:#222222;
                fontColor:#EBEBEB;
                borderColor:#000000;
                borderWeight:thin;
              }"/>
      </layer>

      <layer name="tc-table-base" priority="200" enabled="true">
        <rule target="row"
              selector="kind=comparingall"
              styles="{
                fontName:'Times New Roman';
                fontSize:12;
                horizontal:center;
                vertical:center;
                borderColor:#111111;
                borderWeight:thin;
              }"/>
      </layer>

      <layer name="tc-header" priority="210" enabled="true">
        <rule target="row"
              selector="kind=comparingheader"
              styles="{
                backColor:#222222;
                fontColor:#68D947;
                fontBold:true;
                overflow:wrap;
                autoHeight:true;
              }"/>
      </layer>

      <layer name="tc-data" priority="220" enabled="true">
        <rule target="row"
              selector="kind=comparingdata"
              styles="{
                backColor:#1E1E1E;
                fontColor:#EBEBEB;
                overflow:wrap;
                rowHeight:20;
              }"/>
      </layer>

      <layer name="tc-status-added" priority="230" enabled="true">
        <rule target="row"
              selector="kind=statusadded"
              styles="{
                backColor:#2E7D32;
                fontColor:#EBEBEB;
              }"/>
      </layer>

      <layer name="tc-status-changed" priority="231" enabled="true">
        <rule target="row"
              selector="kind=statuschanged"
              styles="{
                backColor:#7B1FA2;
                fontColor:#EBEBEB;
              }"/>
      </layer>

      <layer name="tc-status-removed" priority="232" enabled="true">
        <rule target="row"
              selector="kind=statusremoved"
              styles="{
                backColor:#B71C1C;
                fontColor:#EBEBEB;
              }"/>
      </layer>

      <layer name="tc-status-default" priority="233" enabled="true">
        <rule target="row"
              selector="kind=statusdefault"
              styles="{
                backColor:#1E1E1E;
                fontColor:#EBEBEB;
              }"/>
      </layer>

      <layer name="tc-autofit-columns" priority="300" enabled="true">
        <rule target="sheet"
              styles="{
                autoFitColumns:true;
              }"/>
      </layer>

      <layer name="tc-clamp-columns" priority="310" enabled="true">
        <rule target="sheet"
              styles="{
                minWidth:5;
                maxWidth:60;
              }"/>
      </layer>
    </stage>
  </sheetPipeline>
</stylePipeline>
