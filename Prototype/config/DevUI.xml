<?xml version="1.0" standalone="yes"?>
<uiDefinition xmlns="urn:excelprototype:profiles" version="1">
  <dataSources>
    <profilesSource name="profilesByMode"
                    defaultMode="Personal Card"
                    modePersonalCard="Personal Card"
                    modeComparing="Comparing"
                    pathPersonalCard="config\modes\PersonalCard"
                    pathComparing="config\modes\TablesComparing"/>
  </dataSources>

  <styles>
    <buttonStyle name="base"
                 backColor="#2F2F2F"
                 textColor="#FFFFFF"
                 borderColor="#505050"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="10"
                 fontBold="true"/>
    <buttonStyle name="accent"
                 backColor="#1F5E9C"
                 textColor="#FFFFFF"
                 borderColor="#163F69"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="10"
                 fontBold="true"/>
    <buttonStyle name="modeChooserHeader"
           backColor="#3C7D22"
           textColor="#0A0A0A"
           borderColor="#3C7D22"
           borderWeight="1"
           fontName="Calibri"
           fontSize="12"
           fontBold="false"/>
    <buttonStyle name="modeChooserOption"
           backColor="#3A3F45"
           textColor="#FFFFFF"
          borderColor="#3A3F45"
           borderWeight="1"
           fontName="Calibri"
           fontSize="12"
           fontBold="false"/>
        <buttonStyle name="modePrimary"
          backColor="#3A3F45"
          textColor="#FFD966"
          borderColor="#3A3F45"
          borderWeight="1"
          fontName="Calibri"
          fontSize="12"
          fontBold="false"/>
        <buttonStyle name="actionNeutral"
          backColor="#3A3F45"
          textColor="#FFD966"
          borderColor="#3A3F45"
          borderWeight="1"
          fontName="Calibri"
          fontSize="12"
          fontBold="false"/>
        <buttonStyle name="actionWarning"
          backColor="#ED7D31"
          textColor="#0A0A0A"
          borderColor="#ED7D31"
          borderWeight="1"
          fontName="Calibri"
          fontSize="12"
          fontBold="false"/>
    <buttonStyle name="modeTimeline"
                 backColor="#0070C0"
                 textColor="#FFFFFF"
                 borderColor="#0070C0"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="14"
                 fontBold="true"/>
    <buttonStyle name="modeState"
                 backColor="#70AD47"
                 textColor="#FFFFFF"
                 borderColor="#70AD47"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="14"
                 fontBold="true"/>
    <buttonStyle name="modeEvents"
                 backColor="#C55A11"
                 textColor="#FFFFFF"
                 borderColor="#C55A11"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="14"
                 fontBold="true"/>
    <buttonStyle name="modeUnknown"
                 backColor="#808080"
                 textColor="#FFFFFF"
                 borderColor="#808080"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="14"
                 fontBold="true"/>
  </styles>

  <layout>
    <stableZone startCol="H" minBufferWidth="5"/>
  </layout>

  <controls>
    <!--
      IMPORTANT: Keep Update Code bound directly to DevTools.dev_UpdateCode.
      If routed through ex_UIActions, that module can be active during import/removal cycle,
      and VBA may re-import action modules with numeric suffixes (duplicates like ...1).
    -->
    <control name="btnUpdateCode"
             type="button"
             sheet="Dev"
             required="true"
             createIfMissing="true"
             macro="DevTools.dev_UpdateCode"
             caption="Update Code"
             globalVisible="true"
             style="actionWarning"
             placement="moveAndSize"
             anchorCell="Q5"
             spanCols="2"
             spanRows="2"/>

    <control name="btnClear"
             type="button"
             sheet="Dev"
             required="true"
             createIfMissing="true"
             macro="ex_UIActions.m_DeleteResultSheets_OnClick"
             caption="Clear"
             globalVisible="true"
             style="actionNeutral"
             placement="moveAndSize"
             anchorCell="Q2"
             spanCols="2"
             spanRows="2"/>

    <control name="btnPersonalCard"
             type="button"
             sheet="Dev"
             required="true"
             createIfMissing="true"
             macro="ex_UIActions.m_ShowPersonalCard_OnClick"
             caption="Personal Card"
             globalVisible="false"
             style="modePrimary"
             placement="moveAndSize"
             anchorCell="K8"
             spanCols="3"
             spanRows="2"/>

    <control name="btnMode"
             type="button"
             sheet="Dev"
             required="true"
             createIfMissing="true"
             macro="ex_UIActions.m_SwitchMode_OnClick"
             caption="Mode [Timeline]"
             globalVisible="false"
             style="modeChooserOption"
             placement="moveAndSize"
             anchorCell="N8"
             spanCols="2"
             spanRows="2">
      <modeVariants source="Settings.OutputMode">
        <variant value="1"
                 display="Timeline"
                 caption="Mode [Timeline]"
                 style="modeChooserOption"/>
        <variant value="2"
                 display="State"
                 caption="Mode [State]"
                 style="modeChooserOption"/>
        <variant value="3"
                 display="Events"
                 caption="Mode [Events]"
                 style="modeChooserOption"/>
      </modeVariants>
    </control>

    <control name="btnComparing"
             type="button"
             sheet="Dev"
             required="true"
             createIfMissing="true"
             macro="ex_UIActions.m_RunComparingTables_OnClick"
             caption="Comparing"
             globalVisible="false"
             style="modePrimary"
             placement="moveAndSize"
             anchorCell="K8"
             spanCols="2"
             spanRows="2"/>

    <control name="btnCustomProfile"
             type="button"
             sheet="Dev"
             required="true"
             createIfMissing="true"
             macro="ex_UIActions.m_ToggleCustomProfile_OnClick"
             caption="Choose profile"
             sourceUriTemplate="config\modes\{activeMode}\DropDownItems.xml#profiles.main"
             refreshOn="activeMode"
             itemStyle="modeChooserOption"
             itemMarginLeft="0"
             itemFirstGap="2"
             itemGap="2"
             itemHeight="16"
             itemMatchWidth="true"
             globalVisible="true"
             style="modeChooserHeader"
             placement="moveAndSize"
             anchorCell="E2"
             spanCols="2"
             spanRows="2"/>

    <control name="btnCustomMode"
             type="button"
             sheet="Dev"
             required="true"
             createIfMissing="true"
             macro="ex_UIActions.m_ToggleCustomMode_OnClick"
             caption="Choose mode"
             sourceUri="config\modes\DropDownItems.xml#modes.main"
             itemStyle="modeChooserOption"
             itemMarginLeft="0"
             itemFirstGap="2"
             itemGap="2"
             itemHeight="16"
             itemMatchWidth="true"
             style="modeChooserHeader"
             placement="moveAndSize"
             anchorCell="K2"
             spanCols="3"
             spanRows="2"/>

    <control name="ddProfile"
             type="dropdown"
             sheet="Dev"
             required="true"
             macro="ex_UIActions.m_OnProfileChanged_OnClick"
             itemsSource="profilesByMode"
             visible="false"
             placement="move"
             anchorCell="E1"
             anchorDx="0"
             anchorDy="2.25"
             width="139.5"
             height="15"/>

    <control name="ddMode"
             type="dropdown"
             sheet="Dev"
             required="true"
             macro="ex_UIActions.m_OnModeChanged_OnClick"
             sourceUri="config\modes\DropDownItems.xml#modes.main"
             selectedItem="Personal Card"
             visible="false"
             left="758.25"
             top="2.25"
             width="156"
             height="15">
      <items>
        <item value="Personal Card"/>
        <item value="Comparing"/>
      </items>
    </control>
  </controls>
</uiDefinition>
