<?xml version="1.0" standalone="yes"?>
<uiDefinition xmlns="urn:excelprototype:profiles" version="2">
  <dataSources>
    <itemsSource name="modesMain"
                 uri="config\modes\DropDownItems.xml#modes.main"/>
    <itemsSource name="profilesMain"
                 uriTemplate="config\modes\{activeMode}\DropDownItems.xml#profiles.main"/>
    <!-- TODO: try remove hardcoded source-name dependency in VBA (profilesFileByMode); -->
    <itemsSource name="profilesFileByMode"
                 uriTemplate="config\modes\{activeMode}\{activeMode}Profiles.xml"/>
  </dataSources>

  <styles>
    <controlStyle name="base"
                 backColor="#2F2F2F"
                 textColor="#FFFFFF"
                 borderColor="#505050"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="10"
                 fontBold="true"/>
    <controlStyle name="accent"
                 backColor="#1F5E9C"
                 textColor="#FFFFFF"
                 borderColor="#163F69"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="10"
                 fontBold="true"/>
    <controlStyle name="modeChooserHeader"
                 backColor="#3C7D22"
                 textColor="#0A0A0A"
                 borderColor="#3C7D22"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="12"
                 fontBold="false"/>
    <controlStyle name="modeChooserOption"
                 backColor="#3A3F45"
                 textColor="#FFFFFF"
                 borderColor="#3A3F45"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="12"
                 fontBold="false"/>
    <controlStyle name="modePrimary"
                 backColor="#3A3F45"
                 textColor="#FFD966"
                 borderColor="#3A3F45"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="12"
                 fontBold="false"/>
    <controlStyle name="actionNeutral"
                 backColor="#3A3F45"
                 textColor="#FFD966"
                 borderColor="#3A3F45"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="12"
                 fontBold="false"/>
    <controlStyle name="actionWarning"
                 backColor="#ED7D31"
                 textColor="#0A0A0A"
                 borderColor="#ED7D31"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="12"
                 fontBold="false"/>
    <controlStyle name="modeTimeline"
                 backColor="#0070C0"
                 textColor="#FFFFFF"
                 borderColor="#0070C0"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="14"
                 fontBold="true"/>
    <controlStyle name="modeState"
                 backColor="#70AD47"
                 textColor="#FFFFFF"
                 borderColor="#70AD47"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="14"
                 fontBold="true"/>
    <controlStyle name="modeEvents"
                 backColor="#C55A11"
                 textColor="#FFFFFF"
                 borderColor="#C55A11"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="14"
                 fontBold="true"/>
    <controlStyle name="modeUnknown"
                 backColor="#808080"
                 textColor="#FFFFFF"
                 borderColor="#808080"
                 borderWeight="1"
                 fontName="Calibri"
                 fontSize="14"
                 fontBold="true"/>
  </styles>

  <layout>
    <stableZone startCol="H" minBufferWidth="5"/>

    <grid sheet="Dev" anchorCell="A1">
      <stackPanel at="r2c5" spanCells="9" spanRows="2" orientation="horizontal">
        <control name="btnCustomProfile"
                 type="dropdownButton"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_ToggleDropdownButton_OnClick"
                 caption="Choose profile"
                 itemsSource="profilesMain"
                 selectionChangedMacro="ex_UIActions.m_OnProfileOptionSelected"
                 itemStyle="modeChooserOption"
                 itemMarginLeft="0"
                 itemFirstGap="2"
                 itemGap="2"
                 itemHeight="16"
                 itemMatchWidth="true"
                 headerShowsSelection="false"
                 globalVisible="true"
                 style="modeChooserHeader"
                 placement="moveAndSize"
                 spanCells="2"
                 spanRows="2"/>

        <border spanCells="4" spanRows="2"/>

        <control name="btnCustomMode"
                 type="dropdownButton"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_ToggleDropdownButton_OnClick"
                 caption="Choose mode"
                 itemsSource="modesMain"
                 selectionChangedMacro="ex_UIActions.m_OnModeOptionSelected"
                 itemStyle="modeChooserOption"
                 itemMarginLeft="0"
                 itemFirstGap="2"
                 itemGap="2"
                 itemHeight="16"
                 itemMatchWidth="true"
                 headerShowsSelection="false"
                 style="modeChooserHeader"
                 placement="moveAndSize"
                 spanCells="3"
                 spanRows="2"/>
      </stackPanel>

      <border at="r8c11" spanCells="3" spanRows="2">
        <control name="btnPersonalCard"
                 type="button"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_ShowPersonalCard_OnClick"
                 caption="Personal Card"
                 globalVisible="false"
                 style="modePrimary"
                 placement="moveAndSize"
                 spanCells="3"
                 spanRows="2"/>

        <control name="btnHealthBenefits"
                 type="button"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_ShowHealthBenefits_OnClick"
                 caption="Health Benefits"
                 globalVisible="false"
                 style="modePrimary"
                 placement="moveAndSize"
                 spanCells="3"
                 spanRows="2"/>

        <control name="btnComparing"
                 type="button"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_RunComparingTables_OnClick"
                 caption="Comparing"
                 globalVisible="false"
                 style="modePrimary"
                 placement="moveAndSize"
                 spanCells="2"
                 spanRows="2"/>

        <control name="btnReportCreation"
                 type="button"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_ShowReportCreation_OnClick"
                 caption="Report Creation"
                 globalVisible="false"
                 style="modePrimary"
                 placement="moveAndSize"
                 spanCells="3"
                 spanRows="2"/>

        <control name="btnSimpleTest"
                 type="button"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_ShowSimpleTest_OnClick"
                 caption="Simple Test"
                 globalVisible="false"
                 style="modePrimary"
                 placement="moveAndSize"
                 spanCells="3"
                 spanRows="2"/>

        <control name="btnMultiSources"
                 type="button"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_ShowMultiSources_OnClick"
                 caption="Run Multi Sources"
                 globalVisible="false"
                 style="modePrimary"
                 placement="moveAndSize"
                 spanCells="3"
                 spanRows="2"/>
      </border>

      <!--
        IMPORTANT: Keep Update Code bound directly to DevTools.dev_UpdateCode.
        If routed through ex_UIActions, that module can be active during import/removal cycle,
        and VBA may re-import action modules with numeric suffixes (duplicates like ...1).
      -->
      <stackPanel at="r2c17" spanCells="2" spanRows="23" orientation="vertical">
        <control name="btnClear"
                 type="button"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_DeleteResultSheets_OnClick"
                 caption="Clear"
                 globalVisible="true"
                 style="actionNeutral"
                 placement="moveAndSize"
                 spanCells="2"
                 spanRows="2"/>

        <border spanCells="2" spanRows="1"/>

        <border spanCells="2" spanRows="2">
          <control name="btnUpdateCode"
                   type="button"
                   required="true"
                   createIfMissing="true"
                   condition="st_ShowUpdateCode=true"
                   macro="DevTools.dev_UpdateCodeFast"
                   caption="Update Code"
                   globalVisible="true"
                   style="actionWarning"
                   placement="moveAndSize"
                   spanCells="2"
                   spanRows="2"/>
        </border>

        <border spanCells="2" spanRows="1"/>

        <border spanCells="2" spanRows="2">
          <control name="btnUpdateUI"
                   type="button"
                   required="true"
                   createIfMissing="true"
                   condition="st_ShowUpdateUI=true"
                   macro="ex_UIActions.m_UpdateUi_OnClick"
                   caption="Update UI"
                   globalVisible="true"
                   style="actionNeutral"
                   placement="moveAndSize"
                   spanCells="2"
                   spanRows="2"/>
        </border>

        <border spanCells="2" spanRows="1"/>

        <control name="btnPreProcessScript"
                 type="button"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_OpenPreProcessScript_OnClick"
                 caption="Pre Process Script"
                 globalVisible="false"
                 style="actionNeutral"
                 placement="moveAndSize"
                 spanCells="2"
                 spanRows="2"/>

        <border spanCells="2" spanRows="1"/>

        <control name="btnPostProcessScript"
                 type="button"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_OpenPostProcessScript_OnClick"
                 caption="Post Process Script"
                 globalVisible="false"
                 style="actionNeutral"
                 placement="moveAndSize"
                 spanCells="2"
                 spanRows="2"/>

        <border spanCells="2" spanRows="1"/>

        <control name="btnLogsToggle"
                 type="button"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_ToggleLogs_OnClick"
                 caption="Logs [Off]"
                 globalVisible="true"
                 style="actionNeutral"
                 placement="moveAndSize"
                 spanCells="2"
                 spanRows="2"/>

        <border spanCells="2" spanRows="1"/>

        <control name="btnOpenLogsFile"
                 type="button"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_OpenLogsFile_OnClick"
                 caption="Open Logs"
                 globalVisible="true"
                 style="actionNeutral"
                 placement="moveAndSize"
                 spanCells="2"
                 spanRows="2"/>
      </stackPanel>

      <stackPanel at="r11c19" spanCells="2" spanRows="8" orientation="vertical">
        <control name="btnOpenPersonalCardProfiles"
                 type="button"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_OpenPersonalCardProfiles_OnClick"
                 caption="PC Profiles"
                 globalVisible="false"
                 style="actionNeutral"
                 placement="moveAndSize"
                 spanCells="2"
                 spanRows="2"/>

        <border spanCells="2" spanRows="1"/>

        <control name="btnOpenPersonalCardResultTemplates"
                 type="button"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_OpenPersonalCardResultTemplates_OnClick"
                 caption="PC Templates"
                 globalVisible="false"
                 style="actionNeutral"
                 placement="moveAndSize"
                 spanCells="2"
                 spanRows="2"/>

        <border spanCells="2" spanRows="1"/>

        <control name="btnOpenPersonalCardSheetStylesPipeline"
                 type="button"
                 required="true"
                 createIfMissing="true"
                 macro="ex_UIActions.m_OpenPersonalCardSheetStylesPipeline_OnClick"
                 caption="PC Styles"
                 globalVisible="false"
                 style="actionNeutral"
                 placement="moveAndSize"
                 spanCells="2"
                 spanRows="2"/>
      </stackPanel>
    </grid>
  </layout>
</uiDefinition>
